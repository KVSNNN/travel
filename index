      /* Sort bookings: Chronological by Payment Due Date (earliest/nearest first) */
      function sortBookings(arr) {
        return arr.slice().sort(function (a, b) {
          var da = parseD(supplierDueDate(a));
          var db = parseD(supplierDueDate(b));
          if (!da && !db) return 0;
          if (!da) return 1;
          if (!db) return -1;
          return da - db;
        });
      }

