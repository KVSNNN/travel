              }
              closeM();
              if (supabaseClient) {
                await loadDataFromSupabase();
              } else {
                applyDataVisibilityFilter();
              }
              render();
            } catch (err) {
              console.error(err);
              toast("Failed to save user", "error");
            }
          });
      }
