                  var newUser = {
                    id: nextId.user++,
                    username: d.username,
                    password: d.password,
                    role: d.role,
                    name: d.name,
                    active: true,
                    parentUser: d.parentUser,
                    createdAt: todayStr()
                  };
                  rawUsers.push(newUser);
                  await addLog("create_admin", "Created user " + d.name);
                  toast("User created (Offline)");
