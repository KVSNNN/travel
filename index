            bnc.innerHTML = '<label class="block text-xs font-semibold text-pri-600/70 uppercase mb-1" id="bnLabel">' + (bl[val] || 'Booking Name') + '</label><input type="text" name="bookingName" required class="w-full border border-cream-300 rounded-lg px-3 py-2.5 text-sm">';
          }
          document.getElementById('flightFields').className = val === 'flight' ? 'grid grid-cols-2 gap-4' : 'hidden';
        };
        window.autoCalc = function (side, idx, source) {
          var f = document.getElementById("bForm");
          if (!f) return;
          var cr = parseFloat(f.customerRate.value) || 0;
          var sr = parseFloat(f.supplierRate.value) || 0;
          function updateRow(rowSide, rowIdx, total) {
            var prefix = rowSide === "customer" ? "customerPayment" : "supplierPayment";
            var pct = f[prefix + rowIdx + "Percent"];
            var amt = f[prefix + rowIdx + "Amount"];
            if (!pct || !amt) return 0;
            if (side === rowSide && idx === rowIdx && source === "percent") {
              amt.value = total && pct.value ? Math.round((total * (parseFloat(pct.value) || 0)) / 100) : "";
            } else if (side === rowSide && idx === rowIdx && source === "amount") {
              pct.value = total && amt.value ? (((parseFloat(amt.value) || 0) / total) * 100).toFixed(2) : "";
            }
            return parseFloat(amt.value) || 0;
          }
          var customerPaid = 0;
          var supplierPaid = 0;
          [1, 2, 3].forEach(function (n) {
            customerPaid += updateRow("customer", n, cr);
            supplierPaid += updateRow("supplier", n, sr);
          });
          f.customerBalanceAmount.value = Math.max(0, cr - customerPaid);
          f.supplierBalanceAmount.value = Math.max(0, sr - supplierPaid);
          var p = cr - sr;
          f.profitDisplay.value = p;
          f.profitDisplay.className =
            "w-full border border-cream-200 bg-green-50 rounded-lg px-3 py-2.5 text-sm font-semibold " +
            (p >= 0 ? "profit-pos" : "profit-neg");
        };
        window.autoUpdateSupplierDueDate = function () {
          var f = document.getElementById("bForm");
          if (!f || !f.supplierPaymentDueDate) return;
          if (f.supplierPayment1Completed && f.supplierPayment1Completed.checked) {
            f.supplierPaymentDueDate.value = f.supplierPayment2Date && f.supplierPayment2Date.value ? f.supplierPayment2Date.value : "";
          }
          if (f.supplierPayment2Completed && f.supplierPayment2Completed.checked) {
            f.supplierPaymentDueDate.value = f.supplierPayment3Date && f.supplierPayment3Date.value ? f.supplierPayment3Date.value : "";
          }
          if (f.supplierPayment3Completed && f.supplierPayment3Completed.checked) {
            f.supplierPaymentDueDate.value = "";
          }
          checkDueBlink();
        };
        window.checkDueBlink = function () {
          var f = document.getElementById("bForm");
          if (!f) return;
          var dStr = f.supplierPaymentDueDate.value;
          if (!dStr) {
            f.supplierPaymentDueDate.classList.remove("due-alert");
            return;
          }
          var d = new Date(dStr);
          var now = new Date();
          now.setHours(0, 0, 0, 0);
          var diff = (d - now) / (1000 * 60 * 60 * 24);
          if (diff <= 2 && diff >= 0)
            f.supplierPaymentDueDate.classList.add("due-alert");
          else f.supplierPaymentDueDate.classList.remove("due-alert");
        };
        autoCalc();
        checkDueBlink();
        document.getElementById("bForm").addEventListener("submit", saveB);
      }
      async function saveB(e) {
        e.preventDefault();
        var fd = new FormData(e.target);
        var d = Object.fromEntries(fd);
        d.clientId = parseInt(d.clientId);
        d.customerRate = parseFloat(d.customerRate) || 0;
        d.supplierRate = parseFloat(d.supplierRate) || 0;
        var customerPaidTotal = 0;
        var supplierPaidTotal = 0;
        [1, 2, 3].forEach(function (n) {
          d["customerPayment" + n + "Amount"] = parseFloat(d["customerPayment" + n + "Amount"]) || 0;
          d["customerPayment" + n + "Percent"] = parseFloat(d["customerPayment" + n + "Percent"]) || 0;
          d["supplierPayment" + n + "Amount"] = parseFloat(d["supplierPayment" + n + "Amount"]) || 0;
          d["supplierPayment" + n + "Percent"] = parseFloat(d["supplierPayment" + n + "Percent"]) || 0;
          d["customerPayment" + n + "Completed"] = d["customerPayment" + n + "Completed"] === "1";
          d["supplierPayment" + n + "Completed"] = d["supplierPayment" + n + "Completed"] === "1";
          customerPaidTotal += d["customerPayment" + n + "Amount"];
          supplierPaidTotal += d["supplierPayment" + n + "Amount"];
        });
        d.amountPaidByCustomer = customerPaidTotal;
        d.customerBalancePaid = d.customerPayment2Amount + d.customerPayment3Amount;
        d.amountPaidToSupplier = supplierPaidTotal;
        d.totalAmountPayable = d.supplierRate;
        d.amountPaid = d.amountPaidToSupplier;
        d.amountCollected = d.customerRate;
        if (d.supplierPayment3Completed) {
          d.supplierPaymentDueDate = "";
        } else if (d.supplierPayment2Completed) {
          d.supplierPaymentDueDate = d.supplierPayment3Date || "";
        } else if (d.supplierPayment1Completed) {
          d.supplierPaymentDueDate = d.supplierPayment2Date || "";
        }
        [
          "bookingDate",
          "travelDate",
          "travelDateTo",
          "supplierPaymentDueDate",
          "customerPayment1Date",
          "customerPayment2Date",
          "customerPayment3Date",
          "supplierPayment1Date",
          "supplierPayment2Date",
          "supplierPayment3Date",
        ].forEach(function (k) {
          if (d[k]) d[k] = fromInp(d[k]);
        });
        d.customerPaidDate = d.customerPayment1Date;
        d.customerBalancePaidDate = d.customerPayment2Date;
        d.supplierPaymentDate = d.supplierPayment1Date;
        d.paymentDueDate = d.supplierPaymentDueDate;
        delete d.customerBalanceAmount;
        delete d.supplierBalanceAmount;
        delete d.profitDisplay;
        if (d.bookingType !== 'flight') {
          delete d.travelFrom;
          delete d.travelTo;
        }
        try {
          if (d.id) {
            d.id = parseInt(d.id);
            d.modifiedBy = currentUser.username;
            d.modifiedAt = nowTS();
            var dbPayload = camelToSnake(d);
            const { error } = await supabaseClient.from("bookings").update(dbPayload).eq("id", d.id);
            if (error) throw error;
            await addLog("edit_booking", "Edited booking " + d.pnrRef);
            toast("Booking updated");
          } else {
            delete d.id;
            d.status = "active";
            d.cancelChangeRemarks = "";
            d.createdBy = currentUser.username;
            d.ownerUser = currentUser.role === "admin" ? currentUser.parentUser : currentUser.username;
            d.createdAt = todayStr();
            d.modifiedBy = "";
            d.modifiedAt = "";
            var dbPayload = camelToSnake(d);
            const { error } = await supabaseClient.from("bookings").insert(dbPayload);
            if (error) throw error;
            await addLog("create_booking", "Created booking " + d.pnrRef);
            toast("Booking created");
          }
          closeM();
          await loadDataFromSupabase();
          render();
        } catch (err) {
          console.error(err);
          toast("Failed to save booking", "error");
        }
      }

      /* ===== CANCEL / CHANGE ===== */
      function cancelBk(id) {
        var b = travelBookings.find(function (x) {
          return x.id == id;
        });
        if (!b) return;
        var cl = gC(b.clientId);
        openM(
          '<div class="w-full max-w-md p-6"><div class="flex items-center justify-between mb-4"><h3 class="font-display font-bold text-red-700 text-xl"><i class="fas fa-ban mr-2"></i>Cancel Booking</h3><button onclick="closeM()" class="text-pri-400 hover:text-pri-600"><i class="fas fa-times"></i></button></div><div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4"><p class="text-sm font-semibold text-red-800">' +
            b.bookingName +
            '</p><p class="text-xs text-red-600">' +
            b.pnrRef +
            " | " +
            (cl ? cl.name : "?") +
            " | " +
            fTravel(b) +
            '</p></div><div class="mb-4"><label class="block text-xs font-semibold text-pri-600/70 uppercase mb-1">Reason for Cancellation (required)</label><textarea id="cancelRm" rows="3" required class="w-full border border-red-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:border-red-500" placeholder="Enter cancellation reason..."></textarea></div><div class="flex gap-3"><button onclick="doCancel(' +
            id +
            ')" class="flex-1 bg-red-500 hover:bg-red-600 text-white py-2.5 rounded-lg text-sm font-semibold">Confirm Cancellation</button><button onclick="closeM()" class="flex-1 border border-cream-300 py-2.5 rounded-lg text-sm text-pri-600">Cancel</button></div></div>',
        );
      }
      async function doCancel(id) {
        var rm = document.getElementById("cancelRm").value.trim();
        if (!rm) {
          toast("Cancellation reason is required", "error");
          return;
        }
        var b = travelBookings.find(function (x) {
          return x.id == id;
        });
        if (!b) return;
        try {
          const { error } = await supabaseClient.from("bookings").update({
            status: "cancelled",
            cancel_change_remarks: rm,
            modified_by: currentUser.username,
            modified_at: nowTS()
          }).eq("id", id);
          if (error) throw error;
          await addLog("cancel_booking", "Cancelled booking " + b.pnrRef + ": " + rm);
          toast("Booking cancelled");
          closeM();
          await loadDataFromSupabase();
          render();
        } catch (err) {
          console.error(err);
          toast("Failed to cancel booking", "error");
        }
      }
      function changeBk(id) {
        var b = travelBookings.find(function (x) {
          return x.id == id;
        });
        if (!b) return;
        var cl = gC(b.clientId);
        openM(
          '<div class="w-full max-w-md p-6"><div class="flex items-center justify-between mb-4"><h3 class="font-display font-bold text-amber-700 text-xl"><i class="fas fa-exchange-alt mr-2"></i>Change Booking</h3><button onclick="closeM()" class="text-pri-400 hover:text-pri-600"><i class="fas fa-times"></i></button></div><div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4"><p class="text-sm font-semibold text-amber-800">' +
            b.bookingName +
            '</p><p class="text-xs text-amber-600">' +
            b.pnrRef +
            " | " +
            (cl ? cl.name : "?") +
            " | " +
            fTravel(b) +
            '</p></div><div class="mb-4"><label class="block text-xs font-semibold text-pri-600/70 uppercase mb-1">Reason for Change (required)</label><textarea id="changeRm" rows="3" required class="w-full border border-amber-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:border-amber-500" placeholder="Describe what changed..."></textarea></div><div class="flex gap-3"><button onclick="doChange(' +
            id +
            ')" class="flex-1 bg-amber-500 hover:bg-amber-600 text-white py-2.5 rounded-lg text-sm font-semibold">Confirm Change</button><button onclick="closeM()" class="flex-1 border border-cream-300 py-2.5 rounded-lg text-sm text-pri-600">Cancel</button></div></div>',
        );
      }
      async function doChange(id) {
        var rm = document.getElementById("changeRm").value.trim();
        if (!rm) {
          toast("Change reason is required", "error");
          return;
        }
        var b = travelBookings.find(function (x) {
          return x.id == id;
        });
        if (!b) return;
        try {
          const { error } = await supabaseClient.from("bookings").update({
            status: "changed",
            cancel_change_remarks: rm,
            modified_by: currentUser.username,
            modified_at: nowTS()
          }).eq("id", id);
          if (error) throw error;
          await addLog("change_booking", "Changed booking " + b.pnrRef + ": " + rm);
          toast("Booking marked as changed");
          closeM();
          await loadDataFromSupabase();
          render();
        } catch (err) {
          console.error(err);
          toast("Failed to change booking", "error");
        }
      }
      function delBk(id) {
        if (!canDel()) {
          toast("Only Super Admin can delete", "error");
          return;
        }
        var b = travelBookings.find(function (x) {
          return x.id == id;
        });
        if (!b) return;
        openM(
          '<div class="w-full max-w-sm p-6 text-center"><div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4"><i class="fas fa-trash text-red-500 text-xl"></i></div><h3 class="font-display font-bold text-pri-800 text-lg mb-2">Delete Booking?</h3><p class="text-sm text-pri-600/60 mb-2">' +
            b.bookingName +
            " (" +
            b.pnrRef +
            ')</p><p class="text-xs text-pri-600/50 mb-6">Moves to Recycle Bin.</p><div class="flex gap-3"><button onclick="doDelBk(' +
            id +
            ')" class="flex-1 bg-red-500 hover:bg-red-600 text-white py-2.5 rounded-lg text-sm font-semibold">Delete</button><button onclick="closeM()" class="flex-1 border border-cream-300 py-2.5 rounded-lg text-sm text-pri-600">Cancel</button></div></div>',
        );
      }
      async function doDelBk(id) {
        var b = travelBookings.find(function (x) {
          return x.id == id;
        });
        if (!b) return;
        try {
          const { error: binError } = await supabaseClient.from("recycle_bin").insert({
            type: "booking",
            data: b,
            deleted_by: currentUser.username,
            deleted_at: nowTS()
          });
          if (binError) throw binError;
          const { error: delError } = await supabaseClient.from("bookings").delete().eq("id", id);
          if (delError) throw delError;
          await addLog("delete_booking", "Deleted booking " + b.pnrRef);
          closeM();
          await loadDataFromSupabase();
          render();
          toast("Booking moved to Recycle Bin", "info");
        } catch (err) {
          console.error(err);
          toast("Failed to delete booking", "error");
        }
      }
      /* ===== BACKUP & RESTORE ===== */
      function rBackup() {
        if (!currentUser || currentUser.role !== "supremeadmin") return '<p class="text-red-500">Access denied.</p>';
        var h = '<div class="grid grid-cols-1 md:grid-cols-2 gap-6">';
        h +=
          '<div class="bg-white rounded-xl border border-cream-300 p-6"><div class="w-12 h-12 rounded-lg bg-green-100 flex items-center justify-center mb-4"><i class="fas fa-download text-green-600 text-xl"></i></div><h3 class="font-display font-bold text-pri-800 text-lg mb-2">Export Data</h3><p class="text-sm text-pri-600/70 mb-6">Download a complete backup of all your clients, bookings, and system logs.</p><button onclick="exportData()" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors flex items-center gap-2 w-full justify-center"><i class="fas fa-file-export"></i> Download JSON File</button></div>';
        h +=
          '<div class="bg-white rounded-xl border border-cream-300 p-6"><div class="w-12 h-12 rounded-lg bg-blue-100 flex items-center justify-center mb-4"><i class="fas fa-upload text-blue-600 text-xl"></i></div><h3 class="font-display font-bold text-pri-800 text-lg mb-2">Import Data</h3><p class="text-sm text-pri-600/70 mb-6">Restore a previously saved backup file. This will replace your current data.</p><input type="file" id="importFile" accept=".json" class="hidden" onchange="importData(event)"><button onclick="document.getElementById(\'importFile\').click()" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors flex items-center gap-2 w-full justify-center"><i class="fas fa-file-import"></i> Upload JSON File</button></div>';
        h +=
          '<div class="bg-white rounded-xl border border-red-200 p-6 md:col-span-2"><div class="w-12 h-12 rounded-lg bg-red-100 flex items-center justify-center mb-4"><i class="fas fa-exclamation-triangle text-red-600 text-xl"></i></div><h3 class="font-display font-bold text-pri-800 text-lg mb-2">Reset System</h3><p class="text-sm text-pri-600/70 mb-6">Clear all current data and restore the default demo dataset. This action cannot be undone unless you have a backup.</p><button onclick="resetData()" class="bg-red-500 hover:bg-red-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors flex items-center gap-2 w-max"><i class="fas fa-trash-alt"></i> Reset to Default Data</button></div></div>';
        return h;
      }
      function exportData() {
        var data = {
          nextId: nextId,
          users: users,
          clients: clients,
          travelBookings: travelBookings,
          recycleBin: recycleBin,
          activityLog: activityLog,
        };
        var dataStr =
          "data:text/json;charset=utf-8," +
          encodeURIComponent(JSON.stringify(data));
        var anchor = document.createElement("a");
        anchor.href = dataStr;
        anchor.download = "TravelCRM_Backup_" + todayStr() + ".json";
        anchor.click();
        toast("Data exported successfully");
      }
      async function importData(e) {
        var file = e.target.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = async function (event) {
          try {
            var data = JSON.parse(event.target.result);
            if (data.users && data.clients && data.travelBookings) {
              toast("Restoring database from file, please wait...", "info");
              await supabaseClient.from("bookings").delete().neq("id", 0);
              await supabaseClient.from("clients").delete().neq("id", 0);
              await supabaseClient.from("users").delete().neq("id", 0);
              await supabaseClient.from("recycle_bin").delete().neq("id", 0);
              await supabaseClient.from("activity_log").delete().neq("id", 0);
              if (data.users.length) {
                await supabaseClient.from("users").insert(camelToSnake(data.users));
              }
              if (data.clients.length) {
                await supabaseClient.from("clients").insert(camelToSnake(data.clients));
              }
              if (data.travelBookings.length) {
                await supabaseClient.from("bookings").insert(camelToSnake(data.travelBookings));
              }
              if (data.recycleBin && data.recycleBin.length) {
                await supabaseClient.from("recycle_bin").insert(camelToSnake(data.recycleBin));
              }
              if (data.activityLog && data.activityLog.length) {
                await supabaseClient.from("activity_log").insert(camelToSnake(data.activityLog));
              }
              await addLog("import_data", "Imported data from backup file");
              toast("Data imported successfully");
              await loadDataFromSupabase();
              render();
            } else {
              toast("Invalid backup file format", "error");
            }
          } catch (err) {
            console.error(err);
            toast("Error restoring data: " + err.message, "error");
          }
          e.target.value = "";
        };
        reader.readAsText(file);
      }
      function resetData() {
        openM(
          '<div class="w-full max-w-sm p-6 text-center"><div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4"><i class="fas fa-exclamation-triangle text-red-500 text-xl"></i></div><h3 class="font-display font-bold text-pri-800 text-lg mb-2">Reset System?</h3><p class="text-sm text-pri-600/60 mb-6">This will delete your database credentials and reload. You will need to reconnect to a database.</p><div class="flex gap-3"><button onclick="doResetData()" class="flex-1 bg-red-500 hover:bg-red-600 text-white py-2.5 rounded-lg text-sm font-semibold">Yes, Disconnect</button><button onclick="closeM()" class="flex-1 border border-cream-300 py-2.5 rounded-lg text-sm text-pri-600">Cancel</button></div></div>',
        );
      }
      async function doResetData() {
        localStorage.removeItem("supabase_url");
        localStorage.removeItem("supabase_key");
        location.reload();
      }
      function saveData() {
        // No-op. Data is saved in real-time to Supabase.
      }

      // Supabase database setup UI handler
      document.getElementById("dbSetupForm").addEventListener("submit", async function(e) {
        e.preventDefault();
        var url = document.getElementById("dbUrlInput").value.trim();
        var key = document.getElementById("dbKeyInput").value.trim();
        var errDiv = document.getElementById("dbSetupError");
        errDiv.classList.add("hidden");
        try {
          var client = window.supabase.createClient(url, key);
          var { error } = await client.from("users").select("id").limit(1);
          if (error) throw error;
          localStorage.setItem("supabase_url", url);
          localStorage.setItem("supabase_key", key);
          dbUrl = url;
          dbKey = key;
          supabaseClient = client;
          await loadDataFromSupabase();
          document.getElementById("dbSetupScreen").classList.add("hidden");
          document.getElementById("loginScreen").classList.remove("hidden");
          toast("Database connected successfully!");
        } catch (err) {
          console.error(err);
          errDiv.classList.remove("hidden");
          errDiv.textContent = "Connection failed: " + (err.message || "Please check URL, Anon Key, or database table configuration.");
        }
      });

      function showDbSetup() {
        document.getElementById("loginScreen").classList.add("hidden");
        document.getElementById("dbSetupScreen").classList.remove("hidden");
      }

      function hideDbSetup() {
        document.getElementById("dbSetupScreen").classList.add("hidden");
        document.getElementById("loginScreen").classList.remove("hidden");
        var errDiv = document.getElementById("dbSetupError");
        if (errDiv) errDiv.classList.add("hidden");
      }

      async function initApp() {
        document.getElementById("dbSetupScreen").classList.add("hidden");
        document.getElementById("loginScreen").classList.remove("hidden");
        
        var hasConfig = initSupabase();
        if (hasConfig) {
          await loadDataFromSupabase();
        }
      }

      // Initialize the application
      initApp();
    </script>
