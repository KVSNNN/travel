      async function markClientDone(id) {
        var c = gC(id);
        if (!c) return;
        var outstanding = travelBookings.filter(function (b) {
          return b.clientId === id && b.status === "active" && !isSettled(b);
        });
        if (outstanding.length > 0) {
          toast(
            "Cannot mark as Done: Outstanding payments exist. Please settle all finances first.",
            "error",
          );
          return;
        }
        try {
          const { error: clientError } = await supabaseClient.from("clients").update({ status: "done" }).eq("id", id);
          if (clientError) throw clientError;
          const { error: bookingsError } = await supabaseClient.from("bookings").update({ status: "completed" }).eq("client_id", id).eq("status", "active");
          if (bookingsError) throw bookingsError;
          await addLog("mark_done", "Marked client " + c.name + " as done.");
          toast("Client marked as completed. All bookings settled.", "info");
          await loadDataFromSupabase();
          render();
        } catch (err) {
          console.error(err);
          toast("Failed to complete client status", "error");
        }
      }
      async function markBookingDone(id) {
        var b = travelBookings.find(function (x) {
          return x.id === id;
        });
        if (!b) return;
        if (!isSettled(b)) {
          toast(
            "Cannot mark as Done: Outstanding payments exist. Please settle finances first.",
            "error",
          );
          return;
        }
        try {
          const { error } = await supabaseClient.from("bookings").update({
            status: "completed",
            modified_by: currentUser ? currentUser.username : "",
            modified_at: nowTS()
          }).eq("id", id);
          if (error) throw error;
          await addLog(
            "mark_booking_done",
            "Marked booking " + b.pnrRef + " as completed.",
          );
          toast("Booking marked as completed and settled.", "info");
          await loadDataFromSupabase();
          render();
        } catch (err) {
          console.error(err);
          toast("Failed to complete booking", "error");
        }
      }
