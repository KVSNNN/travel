        var u = rawUsers.find(function (x) {
          return x.id === id;
        });
        if (!u) return;
        
        var canManage = false;
        if (currentUser.role === "supremeadmin") {
          canManage = (u.username !== currentUser.username);
        } else if (currentUser.role === "superadmin") {
          canManage = (u.parentUser === currentUser.username && u.role === "admin");
        }
        
        if (!canManage) {
          toast("Access denied", "error");
          return;
        }

        try {
          var newActive = !u.active;
          if (supabaseClient) {
            const { error } = await supabaseClient.from("users").update({ active: newActive }).eq("id", id);
            if (error) throw error;
            await loadDataFromSupabase();
          } else {
            u.active = newActive;
            applyDataVisibilityFilter();
