      async function saveC(e) {
        e.preventDefault();
        var fd = new FormData(e.target);
        var d = Object.fromEntries(fd);
        if (d.id) {
          d.id = parseInt(d.id);
          var dbPayload = camelToSnake(d);
          try {
            const { error } = await supabaseClient.from("clients").update(dbPayload).eq("id", d.id);
            if (error) throw error;
            await addLog("edit_client", "Edited client " + d.name);
            toast("Client updated");
          } catch (err) {
            console.error(err);
            toast("Failed to update client", "error");
            return;
          }
        } else {
          delete d.id;
          d.createdAt = todayStr();
          d.status = "active";
          d.createdBy = currentUser.username;
          d.ownerUser = currentUser.role === "admin" ? currentUser.parentUser : currentUser.username;
          var dbPayload = camelToSnake(d);
          try {
            const { error } = await supabaseClient.from("clients").insert(dbPayload);
            if (error) throw error;
            await addLog("create_client", "Created client " + d.name);
            toast("Client added");
          } catch (err) {
            console.error(err);
            toast("Failed to add client", "error");
            return;
          }
        }
        closeM();
        await loadDataFromSupabase();
        render();
      }
      function delC(id) {
        if (!canDel()) {
          toast("Only Super Admin can delete", "error");
          return;
        }
        var c = gC(id);
        if (!c) return;
        openM(
          '<div class="w-full max-w-sm p-6 text-center"><div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4"><i class="fas fa-trash text-red-500 text-xl"></i></div><h3 class="font-display font-bold text-pri-800 text-lg mb-2">Delete ' +
            c.name +
            '?</h3><p class="text-sm text-pri-600/60 mb-6">Moves to Recycle Bin with all bookings.</p><div class="flex gap-3"><button onclick="doDelC(' +
            id +
            ')" class="flex-1 bg-red-500 hover:bg-red-600 text-white py-2.5 rounded-lg text-sm font-semibold">Delete</button><button onclick="closeM()" class="flex-1 border border-cream-300 py-2.5 rounded-lg text-sm text-pri-600">Cancel</button></div></div>',
        );
      }
      async function doDelC(id) {
        var c = gC(id);
        if (!c) return;
        var cb = travelBookings.filter(function (b) {
          return b.clientId === id;
        });
        try {
          var binItems = [];
          binItems.push({
            type: "client",
            data: c,
            deleted_by: currentUser.username,
            deleted_at: nowTS()
          });
          cb.forEach(function (b) {
            binItems.push({
              type: "booking",
              data: b,
              deleted_by: currentUser.username,
              deleted_at: nowTS()
            });
          });
          const { error: binError } = await supabaseClient.from("recycle_bin").insert(camelToSnake(binItems));
          if (binError) throw binError;
          const { error: delError } = await supabaseClient.from("clients").delete().eq("id", id);
          if (delError) throw delError;
          await addLog(
            "delete_client",
            "Deleted client " + c.name + " with " + cb.length + " bookings"
          );
          closeM();
          state.currentView = "clients";
          await loadDataFromSupabase();
          render();
          toast("Client moved to Recycle Bin", "info");
        } catch (err) {
          console.error(err);
          toast("Failed to delete client", "error");
        }
      }

