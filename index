      async function restoreIt(i) {
        var item = recycleBin[i];
        try {
          var dbPayload = camelToSnake(item.data);
          if (item.type === "client") {
            const { error: insError } = await supabaseClient.from("clients").insert(dbPayload);
            if (insError) throw insError;
          } else {
            const { error: insError } = await supabaseClient.from("bookings").insert(dbPayload);
            if (insError) throw insError;
          }
          const { error: delError } = await supabaseClient.from("recycle_bin").delete().eq("id", item.id);
          if (delError) throw delError;
          await addLog(
            "restore",
            "Restored " +
              item.type +
              ": " +
              (item.data.name || item.data.bookingName),
          );
          toast("Record restored");
          await loadDataFromSupabase();
          render();
        } catch (err) {
          console.error(err);
          toast("Failed to restore record", "error");
        }
      }
      function permDel(i) {
        var item = recycleBin[i];
        openM(
          '<div class="w-full max-w-sm p-6 text-center"><div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4"><i class="fas fa-fire text-red-500 text-xl"></i></div><h3 class="font-display font-bold text-pri-800 text-lg mb-2">Permanently Delete?</h3><p class="text-sm text-pri-600/60 mb-6">This cannot be undone.</p><div class="flex gap-3"><button onclick="doPermDel(' +
            item.id +
            ')" class="flex-1 bg-red-500 hover:bg-red-600 text-white py-2.5 rounded-lg text-sm font-semibold">Delete Forever</button><button onclick="closeM()" class="flex-1 border border-cream-300 py-2.5 rounded-lg text-sm text-pri-600">Cancel</button></div></div>',
        );
      }
      async function doPermDel(id) {
        try {
          const { error } = await supabaseClient.from("recycle_bin").delete().eq("id", id);
          if (error) throw error;
          await addLog('permanent_delete', 'Permanently deleted record');
          closeM();
          await loadDataFromSupabase();
          render();
          toast('Permanently deleted', 'info');
